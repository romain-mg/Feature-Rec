# Copy to .env (or just export in your shell). Optional.
# Without a key, AutoDemo runs in offline mode using the known-good scene(s).
ANTHROPIC_API_KEY=

# Optional: override the replication model (default: claude-sonnet-4-6)
# AUTODEMO_MODEL=claude-sonnet-4-6

# Feature-Rec local demo service.
# Expose this service with ngrok/cloudflared and set FEATURE_REC_API_URL in the demo repo.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/postgres
FEATURE_REC_BASE_URL=http://localhost:3000
FEATURE_REC_RUNNER_TOKEN=replace-with-a-shared-secret

# GitHub App credentials for creating Check Runs and PR comments.
# For local-only smoke testing, FEATURE_REC_GITHUB_TOKEN can be used as a fallback.
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
FEATURE_REC_GITHUB_TOKEN=

# Slack App credentials for uploading videos and handling buttons/modals.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
